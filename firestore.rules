rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // User tracking rules
    match /users/{userId} {
      allow get: if (request.auth != null && request.auth.uid == userId) || userId.startsWith('guest_');
      allow create: if (request.auth != null && request.auth.uid == userId) || userId.startsWith('guest_');
      allow update: if (request.auth != null && request.auth.uid == userId) || userId.startsWith('guest_');
      allow list: if true; 
    }

    // Advanced User tracking rules (appUsers)
    match /appUsers/{userId} {
      // Allow any user to track their own activity
      // We use a prefix 'user_' or authenticated UID
      allow get: if true;
      allow create, update: if true; // In production, refine this to check specific fields
      allow list: if true;
    }
    
    // System stats (optional: we can use counts from /users)
  }
}

{
  "entities": {
    "appUsers": {
      "title": "App User",
      "description": "Represents a unique device/user tracking session.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "firstSeenAt": { "type": "string", "format": "date-time" },
        "lastActiveAt": { "type": "string", "format": "date-time" },
        "userAgent": { "type": "string" },
        "installedLikePWA": { "type": "boolean" }
      },
      "required": ["userId", "lastActiveAt"]
    }
  },
  "firestore": {
    "/appUsers/{userId}": {
      "schema": "appUsers",
      "description": "Tracking documents for each unique user session."
    }
  }
}
